<!-- Add Inventory Modal -->
<div id="addInventoryModal" class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 hidden z-50">

  <div class="bg-[#5c0a0a] rounded-xl w-1/2 max-w-2xl p-6 text-white relative">

    <!-- Modal Header -->
    <h2 class="text-xl font-bold mb-4">Add Inventory Item</h2>

    <!-- Modal Form -->
    <form
      id="addInventoryForm"
      class="flex flex-col gap-4"
      method="POST"
      action="/add-inventory"
      enctype="multipart/form-data"
    >

        <!-- Image Preview Box -->
        <div class="col-span-1 flex flex-col items-center">
          <div id="imagePreview" class="border w-1/2 h-48 bg-gray-200 rounded-lg flex items-center justify-center overflow-hidden">
              <span class="text-gray-500 text-xs">No image</span>
          </div>
        </div>

        <!-- 2x2 Container -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Picture Upload -->
          <div>
              <label class="block text-sm font-semibold mb-1">Picture</label>
              <input
              type="file"
              name="picture"
              accept="image/*"
              class="w-full rounded-md p-2 bg-white text-black"
              onchange="previewImage(event)"
              >
          </div>

          <!-- Equipment Name -->
          <div>
              <label class="block text-sm font-semibold mb-1">Equipment Name</label>
              <input
              required
              type="text"
              name="name"
              required
              class="w-full rounded-md p-2 text-black"
              placeholder="Enter equipment name"
              >
          </div>

          <!-- Equipment Type -->
          <div>
              <label class="block text-sm font-semibold mb-1">Type</label>
              <select
              required
              name="type"
              class="w-full rounded-md p-2 text-black"
              >
              <option value="" disabled selected>Select equipment type</option>
              <option value="Electronics">Electronics</option>
              <option value="Optics">Optics</option>
              <option value="Mechanical">Mechanical</option>
              <option value="Measurement">Measurement</option>
              <option value="Electrical">Electrical</option>
              <option value="Others">Others</option>
              </select>
          </div>

          <!-- Quantity -->
          <div>
              <label class="block text-sm font-semibold mb-1">Quantity</label>
              <input
              required
              type="number"
              name="quantity"
              min="1"
              class="w-full rounded-md p-2 text-black"
              placeholder="Enter quantity"
              >
          </div>
        </div>


      <!-- Modal Buttons -->
      <div class="md:col-span-2 flex justify-end space-x-2 mt-4">
        <button
          type="button"
          onclick="closeInventoryModal()"
          class="px-4 py-2 rounded-lg border border-white hover:bg-white hover:text-[#5c0a0a] transition"
        >
          Cancel
        </button>
        <button
          type="submit"
          name="addinventorybtn"
          class="px-4 py-2 rounded-lg bg-green-500 hover:bg-green-600 transition"
        >
          Add Item
        </button>
      </div>

    </form>
  </div>
</div>

<script>
  // Open Modal
  document.getElementById('open_addinventory').addEventListener('click', function() {
    document.getElementById('addInventoryModal').classList.remove('hidden')
  })

  // Close Modal
  function closeInventoryModal() {
    document.getElementById('addInventoryModal').classList.add('hidden')
  }

  // Image Preview Function
  function previewImage(event) {
    const preview = document.getElementById('imagePreview')
    const file = event.target.files[0]

    if(file) {
      const reader = new FileReader()
      reader.onload = function(e) {
        preview.innerHTML = `<img src="${e.target.result}" class="w-full h-full object-contain"/>`
      }
      reader.readAsDataURL(file)
    } else {
      preview.innerHTML = `<span class="text-gray-500 text-xs">No image</span>`
    }
  }
</script>