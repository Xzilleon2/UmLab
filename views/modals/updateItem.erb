<!-- Update Inventory Modal -->
<div id="updateInventoryModal" class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 hidden z-50">
  <div class="bg-[#5c0a0a] rounded-xl w-11/12 max-w-2xl p-6 text-white relative">

    <!-- Modal Header -->
    <h2 class="text-xl font-bold mb-4">Update Inventory Item</h2>

    <!-- Modal Form -->
    <form id="updateInventoryForm" class="grid grid-cols-1 md:grid-cols-2 gap-4" method="POST" action="/update-inventory" enctype="multipart/form-data">

      <!-- Hidden ID -->
      <input type="hidden" id="update_item_id" name="item_id">

      <!-- Image Preview -->
      <div class="col-span-2 flex flex-col items-center">
        <label class="block text-sm font-semibold mb-1">Preview</label>
        <div id="updateImagePreview" class="w-24 h-24 bg-gray-200 rounded-lg flex items-center justify-center overflow-hidden mb-2">
          <span class="text-gray-500 text-xs">No image</span>
        </div>
      </div>

      <!-- Picture Upload -->
      <div>
        <label class="block text-sm font-semibold mb-1">Picture</label>
        <input
          type="file"
          name="picture"
          accept="image/*"
          class="w-full rounded-md p-2 bg-white text-black"
          onchange="previewUpdateImage(event)"
        >
      </div>

      <!-- Equipment Name -->
      <div>
        <label class="block text-sm font-semibold mb-1">Equipment Name</label>
        <input required type="text" id="update_name" name="name" class="w-full rounded-md p-2 text-black">
      </div>

      <!-- Equipment Type -->
      <div>
        <label class="block text-sm font-semibold mb-1">Type</label>
        <select required id="update_type" name="type" class="w-full rounded-md p-2 text-black">
          <option value="" disabled>Select type</option>
          <option value="Electronics">Electronics</option>
          <option value="Optics">Optics</option>
          <option value="Mechanical">Mechanical</option>
          <option value="Measurement">Measurement</option>
          <option value="Electrical">Electrical</option>
          <option value="Others">Others</option>
        </select>
      </div>

      <!-- Quantity -->
      <div>
        <label class="block text-sm font-semibold mb-1">Quantity</label>
        <input required type="number" id="update_quantity" name="quantity" min="1" class="w-full rounded-md p-2 text-black">
      </div>

      <!-- Buttons -->
      <div class="col-span-2 flex justify-end space-x-2 mt-4">
        <button type="button" onclick="closeUpdateInventoryModal()" class="px-4 py-2 rounded-lg border border-white hover:bg-white hover:text-[#5c0a0a] transition">
          Cancel
        </button>
        <button name="updateinventorybtn" type="submit" class="px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-600 transition">
          Update
        </button>
      </div>

    </form>
  </div>
</div>

<script>
  // Open and populate modal with item data
  function openUpdateInventoryModal(button) {
    document.getElementById('updateInventoryModal').classList.remove('hidden');

    document.getElementById('update_item_id').value = button.dataset.id;
    document.getElementById('update_name').value = button.dataset.name;
    document.getElementById('update_type').value = button.dataset.type;
    document.getElementById('update_quantity').value = button.dataset.quantity;

    const preview = document.getElementById('updateImagePreview');
    if (button.dataset.picture) {
      preview.innerHTML = `<img src="/items/${button.dataset.picture}" class="w-full h-full object-contain"/>`;
    } else {
      preview.innerHTML = `<span class="text-gray-500 text-xs">No image</span>`;
    }
  }

  function closeUpdateInventoryModal() {
    document.getElementById('updateInventoryModal').classList.add('hidden');
  }

  // Hide modal when clicking outside
  window.addEventListener('click', function(event) {
    const modal = document.getElementById('updateInventoryModal');
    if (event.target === modal) {
      closeUpdateInventoryModal();
    }
  });

  // Preview uploaded image
  function previewUpdateImage(event) {
    const preview = document.getElementById('updateImagePreview');
    const file = event.target.files[0];

    if(file) {
      const reader = new FileReader();
      reader.onload = function(e) {
        preview.innerHTML = `<img src="${e.target.result}" class="w-full h-full object-contain"/>`;
      }
      reader.readAsDataURL(file);
    } else {
      preview.innerHTML = `<span class="text-gray-500 text-xs">No image</span>`;
    }
  }
</script>