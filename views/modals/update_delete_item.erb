<!-- EDIT INVENTORY MODAL -->
<div id="editInventoryModal" class="hidden fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 z-50">
  <div class="bg-[#5c0a0a] rounded-xl w-1/2 max-w-2xl p-6 text-white relative">
    <h2 class="text-xl font-bold mb-4">Edit Inventory Item</h2>
    <form id="editInventoryForm" method="POST" action="/update-inventory" enctype="multipart/form-data" class="flex flex-col gap-4">
      
      <!-- Image Preview Box -->
      <div class="flex flex-col items-center mb-4">
        <div id="editImagePreview" class="border w-1/2 h-48 bg-gray-200 rounded-lg flex items-center justify-center overflow-hidden">
          <span class="text-gray-500 text-xs">No image</span>
        </div>
      </div>

      <!-- 2x2 Container -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Picture Upload -->
        <div>
          <label class="block text-sm font-semibold mb-1">Picture</label>
          <input type="file" name="picture" accept="image/*" class="w-full rounded-md p-2 bg-white text-black" onchange="previewEditImage(event)">
        </div>

        <!-- Hidden input for existing picture -->
        <input type="hidden" name="existing_picture" id="editInventoryExistingPicture">

        <!-- Equipment Name -->
        <div>
          <label class="block text-sm font-semibold mb-1">Equipment Name</label>
          <input type="text" name="name" id="editInventoryName" required class="w-full rounded-md p-2 text-black">
        </div>

        <!-- Equipment Type -->
        <div>
          <label class="block text-sm font-semibold mb-1">Type</label>
          <select name="type" id="editInventoryType" required class="w-full rounded-md p-2 text-black">
            <option value="" disabled selected>Select equipment type</option>
            <option value="Electronics">Electronics</option>
            <option value="Optics">Optics</option>
            <option value="Mechanical">Mechanical</option>
            <option value="Measurement">Measurement</option>
            <option value="Electrical">Electrical</option>
            <option value="Others">Others</option>
          </select>
        </div>

        <!-- Quantity -->
        <div>
          <label class="block text-sm font-semibold mb-1">Quantity</label>
          <input type="number" name="quantity" id="editInventoryQuantity" min="1" required class="w-full rounded-md p-2 text-black">
        </div>
      </div>

      <!-- Modal Buttons -->
      <div class="flex justify-end gap-2 mt-4">
        <button type="button" onclick="closeEditModal()" class="px-4 py-2 rounded-lg border border-white hover:bg-white hover:text-[#5c0a0a] transition">Cancel</button>
        <button type="submit" class="px-4 py-2 rounded-lg bg-green-500 hover:bg-green-600 transition">Save</button>
      </div>
      
      <input type="hidden" name="inventory_id" id="editInventoryId">
    </form>
  </div>
</div>

<!-- DELETE INVENTORY MODAL -->
<div id="deleteInventoryModal" class="hidden fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 z-50">
  <div class="bg-[#5c0a0a] rounded-xl w-1/3 max-w-sm p-6 text-white relative">
    <h2 class="text-xl font-bold mb-4 text-red-500">Delete Inventory Item</h2>
    <p class="mb-4">Are you sure you want to delete this item? This action cannot be undone.</p>
    <form id="deleteInventoryForm" method="POST" action="/delete-inventory">
      <input type="hidden" name="inventory_id" id="deleteInventoryId">
      <div class="flex justify-end gap-2 mt-4">
        <button type="button" onclick="closeDeleteModal()" class="px-4 py-2 rounded-lg border border-white hover:bg-white hover:text-[#5c0a0a] transition">Cancel</button>
        <button type="submit" class="px-4 py-2 rounded-lg bg-red-500 hover:bg-red-600 transition">Delete</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openEditModal(button) {
    const row = button.closest('tr');
    const id = button.dataset.id;
    const picture = button.dataset.picture; // current image filename
    const name = row.children[1].innerText;
    const quantity = row.children[2].innerText;
    const type = row.children[3].innerText;

    document.getElementById('editInventoryId').value = id;
    document.getElementById('editInventoryName').value = name;
    document.getElementById('editInventoryQuantity').value = quantity;
    document.getElementById('editInventoryType').value = type;

    // Set hidden input for existing picture
    document.getElementById('editInventoryExistingPicture').value = picture || "";

    // Set image preview
    const preview = document.getElementById('editImagePreview');
    if (picture && picture !== "") {
      preview.innerHTML = `<img src="/items/${picture}" class="w-full h-full object-contain"/>`;
    } else {
      preview.innerHTML = `<span class="text-gray-500 text-xs">No image</span>`;
    }

    document.getElementById('editInventoryModal').classList.remove('hidden');
  }
  function closeEditModal() {
    document.getElementById('editInventoryModal').classList.add('hidden');
  }

  function previewEditImage(event) {
    const preview = document.getElementById('editImagePreview');
    const file = event.target.files[0];
    if(file){
      const reader = new FileReader();
      reader.onload = e => preview.innerHTML = `<img src="${e.target.result}" class="w-full h-full object-contain"/>`;
      reader.readAsDataURL(file);
    } else {
      preview.innerHTML = `<span class="text-gray-500 text-xs">No image</span>`;
    }
  }

  // Open / Close Delete Modal
  function deleteItem(button) {
    const id = button.dataset.id;
    document.getElementById('deleteInventoryId').value = id;
    document.getElementById('deleteInventoryModal').classList.remove('hidden');
  }

  function closeDeleteModal() {
    document.getElementById('deleteInventoryModal').classList.add('hidden');
  }
</script>