<!DOCTYPE html>
<html>
    <%= erb :"includes/head" %>
<body class="bg-[#F8F7F4] min-h-screen font-sans text-[#4A0404] pb-32">

  <header class="p-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
    <div class="flex items-center gap-1">
      <div class="font-bold text-xl flex items-center">
        <span>UM</span><span class="text-orange-500 text-2xl">🧪</span><span>Lab</span>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-4 w-full md:w-auto">
      <div class="relative flex-grow md:flex-grow-0">
        <input type="text" placeholder="Hinted search text" class="bg-gray-200/50 border-none rounded-full py-2 px-6 pr-10 w-full md:w-64 focus:ring-2 focus:ring-yellow-600 outline-none text-sm">
        <span class="absolute right-4 top-2 text-gray-500">🔍</span>
      </div>
      
      <div class="flex items-center gap-3">
        <button class="text-2xl">≡</button>
        <select class="border border-gray-400 rounded px-2 py-1 bg-transparent text-sm">
          <option>aa-ZZ</option>
        </select>
      </div>
    </div>
  </header>

  <main class="px-8">
    <h1 class="text-4xl font-bold text-[#C19A27] mb-8">Pick your Equipment</h1>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-7 gap-4">
      <script>
        const grid = document.currentScript.parentElement;
        for (let i = 0; i < 21; i++) {
          grid.innerHTML += `
            <div class="bg-[#600000] rounded-xl overflow-hidden shadow-md flex flex-col border border-[#600000]">
              <div class="p-2 text-[10px] text-yellow-500 font-bold truncate">Equipment name</div>
              <div class="bg-gray-300 aspect-square mx-2 mb-2 rounded-sm"></div>
              <div class="px-2 pb-2 mt-auto">
                <div class="flex justify-between items-center text-[9px] text-white mb-1">
                  <span>quantity</span>
                  <div class="flex items-center gap-2">
                    <button class="text-red-400">-</button>
                    <span>1</span>
                    <button class="text-green-400">+</button>
                  </div>
                </div>
                <button class="w-full bg-transparent border border-yellow-600 text-yellow-500 text-[9px] py-0.5 rounded-full hover:bg-yellow-600 hover:text-white transition-colors">
                  add
                </button>
              </div>
            </div>
          `;
        }
      </script>
    </div>
  </main>

  <footer class="fixed bottom-0 left-0 right-0 bg-[#600000] p-6 rounded-t-3xl flex justify-center gap-8 shadow-2xl">
    <button class="bg-[#C19A27] hover:bg-[#A68320] text-white font-bold py-3 px-16 rounded-2xl w-full max-w-xs transition-transform active:scale-95">
      Reserve
    </button>
    <button class="border-2 border-[#C19A27] text-white py-3 px-16 rounded-2xl w-full max-w-xs hover:bg-[#4A0000] transition-colors">
      Edit your Pick
    </button>
  </footer>

</body>
</html>