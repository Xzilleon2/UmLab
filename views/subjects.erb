<!DOCTYPE html>
<html>
  <!-- Head section: includes meta tags, styles, and scripts -->
  <%= erb :"includes/head" %>
  <!-- Body: Main layout container -->
<body class="bg-[#F8F7F4] flex flex-col items-center justify-center min-h-screen font-sans text-[#4A0404]">

    <!-- Logo section -->
    <div class="absolute top-8 left-8 flex items-center gap-1">
      <img src="/assets/imgs/UMLab_Logo.svg" alt="UMLab Logo" class="h-10 w-auto">
    </div>

  <!-- Main content: Laboratory selection -->
  <div class="text-center w-full max-w-2xl px-4">
    <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-12">
      Choose One Laboratory
    </h1>

    <!-- Laboratory options grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4 max-w-lg mx-auto">
      
      <!-- Physics Laboratory Button -->
      <a href="/kiosk"  class="bg-[#600000] hover:bg-[#4A0000] text-white font-medium py-3 px-10 rounded-full text-lg transition-all uppercase tracking-wider shadow-sm">
        Physics
      </a>
      
      <!-- Biology Laboratory Button -->
      <button class="lab-btn bg-[#600000] hover:bg-[#4A0000] text-white font-medium py-3 px-10 rounded-full text-lg transition-all uppercase tracking-wider shadow-sm">
        Biology
      </button>

      <!-- Civil Laboratory Button -->
      <button class="lab-btn bg-[#600000] hover:bg-[#4A0000] text-white font-medium py-3 px-10 rounded-full text-lg transition-all uppercase tracking-wider shadow-sm">
        Civil
      </button>

      <!-- Chemistry Laboratory Button -->
      <button class="lab-btn bg-[#600000] hover:bg-[#4A0000] text-white font-medium py-3 px-10 rounded-full text-lg transition-all uppercase tracking-wider shadow-sm">
        Chemistry
      </button>

      <!-- Culinary Laboratory Button -->
      <button class="lab-btn bg-[#600000] hover:bg-[#4A0000] text-white font-medium py-3 px-10 rounded-full text-lg transition-all uppercase tracking-wider shadow-sm">
        Culinary
      </button>

      <!-- Electrical Laboratory Button -->
      <button class="lab-btn bg-[#600000] hover:bg-[#4A0000] text-white font-medium py-3 px-10 rounded-full text-lg transition-all uppercase tracking-wider shadow-sm">
        Electrical
      </button>

      <!-- Mechanical Laboratory Button -->
      <button class="lab-btn bg-[#600000] hover:bg-[#4A0000] text-white font-medium py-3 px-10 rounded-full text-lg transition-all uppercase tracking-wider shadow-sm">
        Mechanical
      </button>

      <!-- Hydraulic Laboratory Button -->
      <button class="lab-btn bg-[#600000] hover:bg-[#4A0000] text-white font-medium py-3 px-10 rounded-full text-lg transition-all uppercase tracking-wider shadow-sm">
        Hydraulic
      </button>

    </div>
  </div>

  <!-- Development Notice Modal -->
  <div id="devModal" class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 hidden z-50">
    <div class="bg-[#5c0a0a] rounded-xl w-96 p-6 text-white relative">
      
      <!-- Modal Header -->
      <h2 class="text-xl font-bold mb-4">Notice</h2>
      
      <!-- Modal Body -->
      <p class="mb-6 text-center text-sm">
        This feature is currently under development.
      </p>
      
      <!-- Close Button -->
      <div class="flex justify-center">
        <button
          onclick="closeDevModal()"
          class="px-4 py-2 rounded-lg border border-white hover:bg-white hover:text-[#5c0a0a] transition"
        >
          Close
        </button>
      </div>
    </div>
  </div>

  <script>
    // Open modal for all lab buttons
    const labButtons = document.querySelectorAll('.lab-btn');
    labButtons.forEach(button => {
      button.addEventListener('click', () => {
        document.getElementById('devModal').classList.remove('hidden');
      });
    });

    // Close modal
    function closeDevModal() {
      document.getElementById('devModal').classList.add('hidden');
    }

    // Optional: Close modal when clicking outside
    window.addEventListener('click', function(event) {
      const modal = document.getElementById('devModal');
      if (event.target === modal) {
        closeDevModal();
      }
    });
  </script>

</body>
</html>